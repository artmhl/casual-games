# Supabase — потрібен лише для мультиплеєр-ігор
# Отримай на https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=твоя_урл_адреса_тут
VITE_SUPABASE_ANON_KEY=твій_секретний_ключ_тут

# Інструкція:
# 1. Скопіюй цей файл як .env
# 2. Заповни значення зі свого Supabase проєкту
# 3. Для Vercel: додай ці ж змінні у Dashboard → Settings → Environment Variables
